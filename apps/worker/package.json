{
  "name": "news-worker",
  "private": true,
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "rss-parser": "^3.13.0",
    "bullmq": "^5.13.0"
  },
  "devDependencies": {
    "prisma": "^5.20.0",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.19.0",
    "@types/node": "^20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "worker": "node dist/worker.js",
    "scheduler": "node dist/scheduler.js",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:scheduler": "tsx watch src/scheduler.ts",
    "seed": "ts-node src/seeds/rssSources.ts",
    "pipeline:run": "ts-node src/jobs/runDailyPipeline.ts",
    "fetch:run": "ts-node -e \"require('./src/jobs/fetchRss').runFetchRssJob().then(r=>{console.log(r);process.exit(0)})\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy"
  }
}
